# ──────────────────────────────────────────────────────────────────────────
# Copy to .env.local for local dev; add the same vars in Vercel (Production +
# Preview). Server-side only, never committed.
# ──────────────────────────────────────────────────────────────────────────

# PRIMARY DATA (full stock analysis incl. DCF) -----------------------------
FMP_API_KEY=                 # Financial Modeling Prep, free 250/day

# AI (narrative + last-resort data estimate). Set one or more; the chain tries
# them in order: Gemini, Groq, OpenRouter, Anthropic. All free except Anthropic.
GEMINI_API_KEY=              # https://aistudio.google.com/   (free)
GROQ_API_KEY=                # https://console.groq.com/      (free)
OPENROUTER_API_KEY=          # https://openrouter.ai/         (free models)
# ANTHROPIC_API_KEY=         # paid alternative

# BACKUP DATA SOURCES (free; used when FMP runs out or has no data) ---------
FINNHUB_API_KEY=             # https://finnhub.io/         quotes + peers, 60/min
ALPHAVANTAGE_API_KEY=        # https://www.alphavantage.co/  fundamentals + fund/ETF holdings, 25/day
MASSIVE_API_KEY=             # https://massive.com/  (Polygon) prices + peers, free 5/min
# MASSIVE_BASE_URL=https://api.polygon.io   # override if Massive moves its host
#
# SEC EDGAR powers financial statements (DCF) for free, NO KEY required.
# Stooq powers price history for free, NO KEY required.

# MENTION HISTORY + REDDIT POSTS (optional) --------------------------------
CRON_SECRET=                 # any random string; protects the daily cron
# Upstash Redis (Vercel Marketplace) auto-injects KV_REST_API_URL / _TOKEN
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
